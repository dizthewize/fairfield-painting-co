---
import LeadCaptureForm from './LeadCaptureForm.astro';
import Button from './Button.astro';
import { site } from '../data/site';

interface Props {
  headline?: string;
  sub?: string;
  showForm?: boolean;
  preselectService?: string;
}

const {
  headline = 'Ready for walls that look like new?',
  sub = "We respond within one business day. Fixed-price estimates, real warranties, and no mess left behind.",
  showForm = true,
  preselectService,
} = Astro.props;
---

<section class="bg-accent text-text-inverse relative overflow-hidden">
  <div class="container-site section-py relative z-10">
    <div class={showForm ? 'grid lg:grid-cols-12 gap-10 items-center' : 'max-w-3xl mx-auto text-center'}>
      <div class={showForm ? 'lg:col-span-7' : ''}>
        <span class="eyebrow mb-3 block">Book a walk-through</span>
        <h2 class="font-display font-medium text-3xl md:text-5xl tracking-tight mb-5">
          {headline}
        </h2>
        <p class="text-lg text-text-inverse/80 max-w-xl leading-relaxed mb-7">
          {sub}
        </p>
        <div class="flex flex-wrap gap-3">
          {!showForm && (
            <Button href="/contact#estimate" size="lg">Get a Free Estimate</Button>
          )}
          <a href={site.phoneHref} class="final-cta-phone">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
            </svg>
            <span>
              <span class="block text-xs text-text-inverse/60 font-normal uppercase tracking-wider">Or call us direct</span>
              <span class="text-2xl font-display font-medium text-primary">{site.phone}</span>
            </span>
          </a>
        </div>
      </div>

      {showForm && (
        <div class="lg:col-span-5">
          <LeadCaptureForm dark id="final-estimate" preselectService={preselectService} />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .final-cta-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    color: var(--color-text-inverse);
    padding: 0.75rem 0.25rem;
    transition: opacity 150ms;
  }
  .final-cta-phone:hover { opacity: 0.85; }
  .final-cta-phone svg { color: var(--color-primary); flex-shrink: 0; }
</style>
