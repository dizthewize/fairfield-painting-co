---
import LeadCaptureForm from './LeadCaptureForm.astro';
import Button from './Button.astro';
import { site } from '../data/site';

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  showForm?: boolean;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  compact?: boolean;
}

const {
  eyebrow = `${site.address.city} · Solano County`,
  headline,
  subheadline,
  showForm = false,
  primaryCta = { label: 'Get a Free Estimate', href: '/contact#estimate' },
  secondaryCta,
  compact = false,
} = Astro.props;
---

<section class:list={['hero', compact ? 'hero--compact' : '', showForm ? 'hero--with-form' : '']}>
  <div class="hero-bg hero-bg-placeholder" aria-hidden="true"></div>

  <div class="container-site relative z-10">
    <div class={showForm ? 'grid lg:grid-cols-12 gap-10 items-center' : ''}>
      <div class={showForm ? 'lg:col-span-7' : 'max-w-3xl'}>
        {eyebrow && <span class="hero-eyebrow">{eyebrow}</span>}
        <h1 class="hero-headline">{headline}</h1>
        {subheadline && <p class="hero-sub">{subheadline}</p>}
        <div class="hero-cta-row">
          <Button href={primaryCta.href} size="lg">{primaryCta.label}</Button>
          {secondaryCta && (
            <Button href={secondaryCta.href} size="lg" variant="secondary-inverse">
              {secondaryCta.label}
            </Button>
          )}
        </div>
        <a href={site.phoneHref} class="hero-phone">
          Or call us direct: <span class="underline underline-offset-4">{site.phone}</span>
        </a>
      </div>

      {showForm && (
        <div class="lg:col-span-5">
          <LeadCaptureForm heading="Request Your Free Estimate" id="hero-estimate" />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(720px, 92vh);
    padding-top: 7rem;
    padding-bottom: 4rem;
    display: flex;
    align-items: center;
    color: var(--color-text-inverse);
    overflow: hidden;
  }
  .hero--compact {
    min-height: auto;
    padding-top: 8rem;
    padding-bottom: 4rem;
  }
  .hero--with-form { padding-top: 7rem; padding-bottom: 5rem; }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: rgba(250, 246, 239, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }
  .hero-headline {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
    color: var(--color-text-inverse);
  }
  .hero-sub {
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    font-weight: 400;
    margin: 0 0 2rem;
    max-width: 52ch;
    color: rgba(250, 246, 239, 0.9);
    line-height: 1.55;
  }
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-phone {
    display: inline-block;
    font-size: 0.9375rem;
    color: rgba(250, 246, 239, 0.8);
  }
  .hero-phone:hover { color: var(--color-primary); }
</style>
