---
interface Props {
  name: string;
  slug: string;
  short: string;
}

const { name, slug, short } = Astro.props;
---

<a href={`/services/${slug}`} class="service-card group">
  <div class="service-card-image service-image-placeholder" aria-hidden="true"></div>
  <div class="service-card-body">
    <h3 class="service-card-title">{name}</h3>
    <p class="service-card-benefit">{short}</p>
    <span class="service-card-link">
      Learn more <span class="service-card-arrow" aria-hidden="true">→</span>
    </span>
  </div>
</a>

<style>
  .service-card {
    display: block;
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 200ms ease-out;
    color: inherit;
  }
  .service-card:hover { transform: translateY(-3px); }
  .service-card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform 400ms ease-out;
  }
  .service-card:hover .service-card-image {
    transform: scale(1.03);
  }
  .service-card-body {
    padding: 1.25rem 0 0.5rem;
  }
  .service-card-title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 1.75rem;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
    color: var(--color-text);
  }
  .service-card-benefit {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0 1rem;
    line-height: 1.55;
  }
  .service-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9375rem;
  }
  .service-card-arrow {
    transition: transform 200ms ease-out;
    display: inline-block;
  }
  .service-card:hover .service-card-arrow {
    transform: translateX(4px);
  }
</style>
