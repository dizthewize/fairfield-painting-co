---
import { services } from '../data/site';
import Button from './Button.astro';

interface Props {
  heading?: string;
  dark?: boolean;
  id?: string;
  preselectService?: string;
}

const {
  heading = 'Request Your Free Estimate',
  dark = false,
  id = 'estimate',
  preselectService,
} = Astro.props;
---

<form
  name="estimate"
  method="POST"
  data-netlify="true"
  data-netlify-honeypot="website"
  id={id}
  class:list={['lead-form', dark ? 'lead-form--dark' : '']}
>
  <input type="hidden" name="form-name" value="estimate" />
  <p class="hidden">
    <label>Don't fill this out: <input name="website" tabindex="-1" autocomplete="off" /></label>
  </p>

  {heading && <h3 class="lead-form-heading">{heading}</h3>}

  <div class="form-row">
    <label for={`${id}-name`} class="form-label">Name</label>
    <input
      id={`${id}-name`}
      name="name"
      type="text"
      autocomplete="name"
      required
      class="form-input"
      placeholder="Jane Homeowner"
    />
  </div>

  <div class="form-row">
    <label for={`${id}-phone`} class="form-label">Phone</label>
    <input
      id={`${id}-phone`}
      name="phone"
      type="tel"
      inputmode="tel"
      autocomplete="tel"
      required
      class="form-input"
      placeholder="(707) 555-0137"
    />
  </div>

  <div class="form-row">
    <label for={`${id}-email`} class="form-label">Email</label>
    <input
      id={`${id}-email`}
      name="email"
      type="email"
      autocomplete="email"
      required
      class="form-input"
      placeholder="jane@example.com"
    />
  </div>

  <div class="form-row">
    <label for={`${id}-service`} class="form-label">Service Type</label>
    <select id={`${id}-service`} name="service" required class="form-select">
      <option value="">Choose a service…</option>
      {services.map((s) => (
        <option value={s.name} selected={preselectService === s.slug}>
          {s.name}
        </option>
      ))}
      <option value="Not sure yet">Not sure yet</option>
    </select>
  </div>

  <div class="form-row">
    <label for={`${id}-project`} class="form-label">Describe your project <span class="text-text-muted font-normal">(optional)</span></label>
    <textarea
      id={`${id}-project`}
      name="project"
      rows="3"
      class="form-textarea"
      placeholder="A few sentences about what you're looking to paint…"
    ></textarea>
  </div>

  <Button type="submit" size="lg" fullWidth>Request My Free Estimate</Button>

  <p class="lead-form-trust">
    Licensed &amp; Insured · No obligation · We respond within one business day.
  </p>
</form>

<style>
  .lead-form {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 4px 14px rgba(31, 27, 23, 0.08);
  }
  .lead-form--dark {
    background: rgba(250, 246, 239, 0.05);
    border: 1px solid rgba(250, 246, 239, 0.15);
    color: var(--color-text-inverse);
  }
  .lead-form--dark .lead-form-heading { color: var(--color-text-inverse); }
  .lead-form--dark .form-label { color: rgba(250, 246, 239, 0.75); }
  .lead-form--dark .form-input,
  .lead-form--dark .form-select,
  .lead-form--dark .form-textarea {
    background: rgba(250, 246, 239, 0.96);
    color: var(--color-text);
  }
  .lead-form--dark .lead-form-trust {
    color: rgba(250, 246, 239, 0.65);
  }

  .lead-form-heading {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    color: var(--color-text);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .form-input,
  .form-select,
  .form-textarea {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    padding: 0.75rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: #fff;
    color: var(--color-text);
    width: 100%;
    transition: border-color 120ms, box-shadow 120ms;
  }
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(184, 105, 30, 0.25);
  }
  .form-textarea {
    resize: vertical;
    min-height: 84px;
  }

  .lead-form-trust {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0.875rem 0 0;
    text-align: center;
    line-height: 1.5;
  }
</style>
