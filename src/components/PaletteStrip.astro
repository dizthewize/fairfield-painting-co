---
import { palette } from '../data/site';
---

<section class="section-py-sm">
  <div class="container-site">
    <div class="max-w-3xl mb-8">
      <span class="eyebrow mb-3 block">Solano palette · 2026</span>
      <h2 class="font-display font-medium text-2xl md:text-3xl tracking-tight">
        Not sure what color? We'll walk you through it.
      </h2>
      <p class="mt-3 text-text-muted max-w-xl leading-relaxed">
        Every estimate includes a free color consultation — fan decks, sample boards, and honest advice on what'll work in your light.
      </p>
    </div>

    <div class="palette-strip" role="img" aria-label="Curated color palette: Revere Pewter, Edgecomb Gray, Dried Thyme, Hale Navy, Cracked Pepper">
      {palette.map((chip) => (
        <div
          class="palette-chip"
          style={`background:${chip.hex};color:${chip.textLight ? '#FAF6EF' : '#1F1B17'}`}
        >
          <span class="palette-chip-label">{chip.name}</span>
          <span class="palette-chip-hex">{chip.hex.toUpperCase()}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .palette-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  @media (max-width: 640px) {
    .palette-strip {
      grid-template-columns: 1fr;
    }
  }
  .palette-chip {
    height: 140px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.125rem;
  }
  @media (max-width: 640px) {
    .palette-chip { height: 72px; }
  }
  .palette-chip-label {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }
  .palette-chip-hex {
    font-size: 0.6875rem;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.03em;
    opacity: 0.75;
  }
</style>
