---
import { site } from '../data/site';
---

<div class="mobile-sticky md:hidden" role="region" aria-label="Quick actions">
  <a href={site.phoneHref} class="mobile-sticky-btn mobile-sticky-call" aria-label={`Call ${site.name}`}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
    </svg>
    Call
  </a>
  <a href="/contact#estimate" class="mobile-sticky-btn mobile-sticky-quote">
    Free Estimate
  </a>
</div>

<style>
  .mobile-sticky {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    display: flex;
    gap: 0.5rem;
    padding: 0.625rem 0.75rem calc(0.625rem + env(safe-area-inset-bottom, 0));
    background: var(--color-accent);
    border-top: 1px solid var(--color-primary);
    box-shadow: 0 -8px 24px rgba(31, 27, 23, 0.2);
  }
  .mobile-sticky-btn {
    flex: 1;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 120ms;
  }
  .mobile-sticky-call {
    background: transparent;
    color: var(--color-text-inverse);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .mobile-sticky-quote {
    background: var(--color-primary);
    color: #fff;
  }
  .mobile-sticky-btn:active { opacity: 0.8; }
</style>
