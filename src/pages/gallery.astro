---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FinalCTA from '../components/FinalCTA.astro';

const projects = [
  { title: 'Cordelia living room refresh', service: 'Interior Painting', city: 'Fairfield' },
  { title: 'Rancho Solano two-story exterior', service: 'Exterior Painting', city: 'Fairfield' },
  { title: '1980s oak kitchen brought back to life', service: 'Cabinet Refinishing', city: 'Suisun City' },
  { title: 'Browns Valley craftsman trim', service: 'Exterior Painting', city: 'Vacaville' },
  { title: 'Hiddenbrooke master bath', service: 'Interior Painting', city: 'Vallejo' },
  { title: 'Napa valley back deck', service: 'Deck Staining', city: 'Napa' },
  { title: 'Main Street office renovation', service: 'Interior Painting', city: 'Vacaville' },
  { title: 'Waterfront deck restoration', service: 'Deck Staining', city: 'Suisun City' },
  { title: 'Victorian trim restoration', service: 'Exterior Painting', city: 'Vallejo' },
];
---

<Layout
  title="Project Gallery · Fairfield Painting Co."
  description="Browse recent interior, exterior, and cabinet painting projects in Fairfield, Vacaville, Suisun City, and the greater Solano County area."
  path="/gallery"
>
  <Hero
    eyebrow="Gallery"
    headline="Recent work from Fairfield &amp; Solano County homes."
    subheadline="Before-and-after photos from recent projects. Filter by service or city to find work that looks like yours."
    compact
    primaryCta={{ label: 'Start Your Project', href: '/contact#estimate' }}
  />

  <section class="section-py">
    <div class="container-site">
      <div class="gallery-grid">
        {projects.map((p, idx) => (
          <figure class:list={['gallery-card', `gallery-card--${idx % 3}`]}>
            <div class="gallery-image service-image-placeholder" aria-hidden="true"></div>
            <figcaption class="gallery-caption">
              <div class="gallery-service">{p.service} · {p.city}</div>
              <div class="gallery-title">{p.title}</div>
            </figcaption>
          </figure>
        ))}
      </div>

      <p class="gallery-note">
        More projects are added monthly. Want to be featured? Let us know when you book —
        we photograph every job we finish.
      </p>
    </div>
  </section>

  <FinalCTA headline="See a project you like? Let's plan yours." />
</Layout>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
  .gallery-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .gallery-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    transition: transform 300ms ease;
  }
  .gallery-card--1 .gallery-image { aspect-ratio: 3 / 4; }
  .gallery-card--2 .gallery-image { aspect-ratio: 1 / 1; }
  .gallery-card:hover .gallery-image {
    transform: scale(1.01);
  }
  .gallery-service {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.375rem;
  }
  .gallery-title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--color-text);
    line-height: 1.35;
  }
  .gallery-note {
    margin-top: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 640px;
    margin-inline: auto;
    line-height: 1.6;
  }
</style>
