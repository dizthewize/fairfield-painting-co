---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout
  title="Page Not Found · Fairfield Painting Co."
  description="We couldn't find that page. Head back to the homepage or get a free estimate."
  path="/404"
>
  <section class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="container-site max-w-3xl text-center">
      <span class="eyebrow mb-3 block">404</span>
      <h1 class="font-display font-medium text-4xl md:text-6xl tracking-tight mb-5">
        That page doesn't exist.
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-8">
        The page you're looking for may have moved or isn't here. Head back to the homepage or book
        a free estimate.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <Button href="/" size="lg">Back to Home</Button>
        <Button href="/contact#estimate" size="lg" variant="secondary">Get a Free Estimate</Button>
      </div>
    </div>
  </section>
</Layout>
